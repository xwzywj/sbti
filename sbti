                <button id="start-btn" class="w-full bg-primary hover:bg-primary/90 text-white font-medium py-3 px-6 rounded-full transition-all duration-300 ease-in-out shadow-md hover:shadow-lg">
                    开始测试
                </button>
                <p class="text-textLight/70 text-sm mt-6">共31题，预计需要3分钟</p>
            </div>
        </div>

        <!-- 测试题目页面 (初始隐藏) -->
        <div id="quiz-screen" class="hidden">
            <!-- 进度条 -->
            <div class="w-full bg-gray-200 rounded-full h-2.5 mb-6 overflow-hidden">
                <div id="progress-bar" class="bg-primary h-2.5 rounded-full transition-all duration-500 ease-in-out" style="width: 0%"></div>
            </div>
            
            <!-- 题目卡片 -->
            <div class="bg-card rounded-2xl p-6 card-shadow mb-6">
                <div class="flex justify-between items-center mb-4">
                    <span id="question-number" class="text-sm text-textLight font-medium">问题 1/31</span>
                    <span class="text-sm text-primary font-medium" id="progress-text">0%</span>
                </div>
                
                <h2 id="question-text" class="text-xl font-semibold mb-6">加载中...</h2>
                
                <div class="space-y-4" id="options-container">
                    <!-- 选项将通过JS动态生成 -->
                </div>
                
                <!-- 导航按钮 -->
                <div class="flex justify-between mt-8">
                    <button id="prev-btn" class="flex items-center gap-1 px-4 py-2 rounded-full border border-gray-200 text-textLight hover:bg-gray-50 transition-all disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                        <i class="fa fa-arrow-left"></i>
                        <span>上一题</span>
                    </button>
                    <button id="next-btn" class="flex items-center gap-1 bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-full transition-all disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                        <span>下一题</span>
                        <i class="fa fa-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- 结果页面 (初始隐藏) -->
        <div id="result-screen" class="hidden">
            <div class="bg-card rounded-2xl p-8 card-shadow text-center">
                <div class="flex justify-center mb-6">
                    <div class="w-20 h-20 rounded-full bg-secondary/20 flex items-center justify-center">
                        <i class="fa fa-trophy text-secondary text-3xl"></i>
                    </div>
                </div>
                <h2 class="text-2xl font-bold mb-2">测试完成!</h2>
                <p class="text-textLight mb-6">你的Sbti人格类型分析结果</p>
                
                <!-- 结果图表 -->
                <div class="h-64 mb-8">
                    <canvas id="result-chart"></canvas>
                </div>
                
                <!-- 人格结果 -->
                <div id="personality-result" class="bg-neutral rounded-xl p-6 mb-6">
                    <h3 class="text-xl font-bold mb-2" id="personality-type">加载中...</h3>
                    <p class="text-textLight" id="personality-desc">加载中...</p>
                </div>
                
                <button id="restart-btn" class="w-full bg-primary hover:bg-primary/90 text-white font-medium py-3 px-6 rounded-full transition-all duration-300 ease-in-out shadow-md hover:shadow-lg">
                    重新测试
                </button>
            </div>
        </div>
    </div>

    <script>
        // 测试题目数据
        const questions = [
