            { q: "朋友向你倾诉烦恼，你会?", options: ["感同身受地安慰", "分析问题给出建议", "讲个笑话转移注意力"] },
            { q: "周末你更愿意?", options: ["宅家独处", "和朋友聚会", "参加户外活动"] },
            { q: "面对压力，你通常会?", options: ["冷静思考解决方案", "向他人寻求帮助", "通过娱乐方式放松"] },
            { q: "你更喜欢哪种早餐?", options: ["精致的西餐", "传统的中式早餐", "随便吃点"] },
            { q: "当你在做决定时，你更依赖?", options: ["直觉和感觉", "逻辑和分析", "他人的意见"] },
            { q: "你通常如何度过夜晚?", options: ["阅读或学习", "刷手机/追剧", "社交或娱乐"] },
            { q: "你对计划的态度是?", options: ["喜欢详细规划", "有大致方向即可", "走一步看一步"] },
            { q: "遇到陌生人，你会?", options: ["保持距离", "主动交流", "等待对方先开口"] },
            { q: "你认为自己更像?", options: ["感性的艺术家", "理性的思考者", "热情的行动派"] },
            { q: "当你犯错时，你会?", options: ["自责难过很久", "分析原因吸取教训", "一笑置之继续前进"] },
            { q: "你更喜欢哪种天气?", options: ["阴雨绵绵", "阳光明媚", "大雪纷飞"] },
            { q: "朋友邀请你参加派对，你会?", options: ["找理由拒绝", "犹豫后决定去", "欣然答应"] },
            { q: "你解决冲突的方式是?", options: ["回避冲突", "理性沟通", "情绪化对抗"] },
            { q: "你通常的睡眠习惯是?", options: ["规律作息", "熬夜早起", "随心所欲"] },
            { q: "当你学习新技能时，你会?", options: ["先研究理论", "直接动手实践", "找人教你"] },
            { q: "你更喜欢的音乐类型是?", options: ["安静舒缓", "动感节奏", "各种类型都喜欢"] },
            { q: "你对时间的观念是?", options: ["总是提前到达", "准时到达", "经常迟到"] },
            { q: "你处理压力的方式是?", options: ["独自消化", "找人倾诉", "通过运动释放"] },
            { q: "你更喜欢的食物是?", options: ["精致料理", "家常便饭", "快餐小吃"] },
            { q: "当你面对挑战时，你会?", options: ["感到焦虑", "冷静应对", "兴奋挑战"] },
            { q: "你更擅长?", options: ["感受情绪", "分析问题", "组织行动"] },
            { q: "你对社交的态度是?", options: ["需要独处充电", "享受社交乐趣", "无所谓"] },
            { q: "你做事情通常?", options: ["追求完美", "注重结果", "重在过程"] },
            { q: "你更喜欢的颜色是?", options: ["冷色调", "暖色调", "明亮色彩"] },
            { q: "当你有了新想法，你会?", options: ["反复思考", "立即行动", "告诉别人征求意见"] },
            { q: "你更像?", options: ["梦想家", "实干家", "社交家"] },
            { q: "你处理物品的方式是?", options: ["保留一切", "断舍离", "随机存放"] },
            { q: "你更喜欢的假期活动是?", options: ["安静阅读", "探索新地方", "热闹聚会"] },
            { q: "你对未来的态度是?", options: ["充满期待", "谨慎规划", "顺其自然"] },
            { q: "如果可以变成一种动物，你会选?", options: ["猫 - 高冷神秘", "狗 - 热情忠诚", "狐狸 - 聪明机智"] }
        ];

        // 人格类型结果
        const personalityTypes = [
            { type: "🎭 多情者", desc: "情感丰富，内心戏十足，是朋友圈中的情绪价值担当，总能敏锐捕捉他人的情感变化。" },
            { type: "💀 死者", desc: "看淡一切，佛系通透，对世间万物都有一种"生人勿近"的疏离感，拥有超越年龄的成熟与沧桑。" },
            { type: "🤡 小丑", desc: "天生乐天派，自带搞笑属性，总能用幽默化解尴尬，是大家的开心果，治愈力满分。" },
            { type: "😐 无所谓人", desc: "主打一个"随缘"，万事皆可，万物都行，没有强烈的主见，随和到让人怀疑人生。" },
            { type: "😏 拿捏者", desc: "智商在线，情商爆表，在人际交往中总能精准拿捏分寸，看似漫不经心，实则运筹帷幄。" },
            { type: "💃 尤物", desc: "自信迷人，自带气场，无论走到哪里都是焦点，对自己的魅力有绝对的自信。" }
        ];

        // 全局变量
        let currentQuestion = 0;
        let answers = [];
        let selectedOptionIndex = -1;

        // DOM 元素
        const welcomeScreen = document.getElementById('welcome-screen');
        const quizScreen = document.getElementById('quiz-screen');
        const resultScreen = document.getElementById('result-screen');
        const startBtn = document.getElementById('start-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const restartBtn = document.getElementById('restart-btn');
        const questionNumber = document.getElementById('question-number');
        const questionText = document.getElementById('question-text');
        const optionsContainer = document.getElementById('options-container');
        const progressBar = document.getElementById('progress-bar');
        const progressText = document.getElementById('progress-text');

        // 开始测试
        startBtn.addEventListener('click', () => {
            welcomeScreen.classList.add('hidden');
            quizScreen.classList.remove('hidden');
            loadQuestion();
        });

        // 重新测试
        restartBtn.addEventListener('click', () => {
            currentQuestion = 0;
            answers = [];
            selectedOptionIndex = -1;
            resultScreen.classList.add('hidden');
            welcomeScreen.classList.remove('hidden');
        });

        // 上一题
        prevBtn.addEventListener('click', () => {
            if (currentQuestion > 0) {
                currentQuestion--;
                selectedOptionIndex = answers[currentQuestion] !== undefined ? answers[currentQuestion] : -1;
                loadQuestion();
                updateNavigationButtons();
            }
        });

        // 下一题
        nextBtn.addEventListener('click', () => {
            if (selectedOptionIndex === -1) {
                showToast('请选择一个选项');
                return;
            }

            answers[currentQuestion] = selectedOptionIndex;

            if (currentQuestion < questions.length - 1) {
                currentQuestion++;
                selectedOptionIndex = answers[currentQuestion] !== undefined ? answers[currentQuestion] : -1;
                loadQuestion();
                updateNavigationButtons();
            } else {
                // 显示结果
                showResult();
            }
        });

        // 加载题目
        function loadQuestion() {
            const question = questions[currentQuestion];
            
            // 更新题目编号和进度
            questionNumber.textContent = `问题 ${currentQuestion + 1}/${questions.length}`;
            const progress = ((currentQuestion + 1) / questions.length) * 100;
            progressBar.style.width = `${progress}%`;
            progressText.textContent = `${Math.round(progress)}%`;
            
            // 更新题目文本
            questionText.textContent = question.q;
            
            // 清空选项容器
            optionsContainer.innerHTML = '';
            
            // 添加选项
            question.options.forEach((option, index) => {
                const optionElement = document.createElement('div');
                optionElement.className = `option-hover p-4 rounded-lg border ${selectedOptionIndex === index ? 'border-primary bg-primary/10' : 'border-gray-200 hover:border-primary/50 hover:bg-primary/5'} cursor-pointer`;
                optionElement.innerHTML = `
                    <label class="flex items-center cursor-pointer">
                        <input type="radio" name="option" value="${index}" class="hidden" ${selectedOptionIndex === index ? 'checked' : ''}>
                        <span class="w-6 h-6 flex items-center justify-center rounded-full ${selectedOptionIndex === index ? 'bg-primary text-white' : 'bg-gray-100 text-textLight mr-3'}">${index + 1}</span>
                        <span>${option}</span>
                    </label>
                `;
                
                optionElement.addEventListener('click', () => {
                    selectedOptionIndex = index;
                    updateOptions();
                    nextBtn.disabled = false;
                });
                
                optionsContainer.appendChild(optionElement);
            });
            
            // 滚动到顶部
            window.scrollTo(0, 0);
        }

        // 更新选项样式
        function updateOptions() {
            const options = optionsContainer.querySelectorAll('.option-hover');
            options.forEach((option, index) => {
                if (selectedOptionIndex === index) {
                    option.classList.add('border-primary', 'bg-primary/10');
                    option.classList.remove('border-gray-200', 'hover:border-primary/50', 'hover:bg-primary/5');
                } else {
                    option.classList.remove('border-primary', 'bg-primary/10');
                    option.classList.add('border-gray-200', 'hover:border-primary/50', 'hover:bg-primary/5');
                }
            });
        }

        // 更新导航按钮状态
        function updateNavigationButtons() {
            prevBtn.disabled = currentQuestion === 0;
            nextBtn.disabled = currentQuestion === questions.length - 1;
            
            // 如果是最后一题，改变按钮文字
            if (currentQuestion === questions.length - 1) {
                nextBtn.innerHTML = '<span>查看结果</span><i class="fa fa-bar-chart"></i>';
            } else {
                nextBtn.innerHTML = '<span>下一题</span><i class="fa fa-arrow-right"></i>';
            }