    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#7C3AED', // 主色：柔和紫
                        secondary: '#2DD4BF', // 辅助色：薄荷绿
                        neutral: '#F8FAFC', // 背景色：浅灰白
